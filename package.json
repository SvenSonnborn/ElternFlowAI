{
  "name": "eltern-flow-ai",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "NODE_OPTIONS=--dns-result-order=ipv4first expo start",
    "android": "NODE_OPTIONS=--dns-result-order=ipv4first expo run:android",
    "ios": "NODE_OPTIONS=--dns-result-order=ipv4first expo run:ios",
    "web": "NODE_OPTIONS=--dns-result-order=ipv4first expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run format:check && bun run lint && bun run typecheck",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "i18next": "^25",
    "nativewind": "^4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.17",
    "zustand": "^5"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "eslint": "^9",
    "eslint-config-expo": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.4.2",
    "jest-expo": "^55.0.17",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-test-renderer": "19.1.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.4"
  },
  "private": true
}
